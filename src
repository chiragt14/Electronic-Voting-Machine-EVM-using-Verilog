
module evm(
input clk,
input reset,
input vote1,
input vote2,
input vote3,
input vote4,
output reg[7:0] count1,
output reg[7:0] count2,
output reg[7:0] count3,
output reg[7:0] count4);
always @(posedge clk or posedge reset)
begin
if(reset)
begin
count1 <=0;
count2 <=0;
count3 <=0;
count4 <=0;
end
else
begin
if(vote1)
count1 <= count1+1;
else if(vote2)
count2 <= count2+1;
else if(vote3)
count3 <= count3+1;
else if(vote4)
count4 <= count4+1;
end
end
endmodule
